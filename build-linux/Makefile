http: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 http
.PHONY : http

# fast build rule for target.
http/fast:
	$(MAKE) $(MAKESILENT) -f src/plugins/Transports/http/CMakeFiles/http.dir/build.make src/plugins/Transports/http/CMakeFiles/http.dir/build
.PHONY : http/fast

